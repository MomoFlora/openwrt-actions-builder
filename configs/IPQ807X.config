CONFIG_TARGET_DEVICE_qualcommax_ipq807x_DEVICE_prpl_haze=y	
CONFIG_TARGET_DEVICE_qualcommax_ipq807x_DEVICE_qnap_301w=y	
CONFIG_TARGET_DEVICE_qualcommax_ipq807x_DEVICE_redmi_ax6-stock=y	
CONFIG_TARGET_DEVICE_qualcommax_ipq807x_DEVICE_redmi_ax6=y	
CONFIG_TARGET_DEVICE_qualcommax_ipq807x_DEVICE_spectrum_sax1v1k=y	
CONFIG_TARGET_DEVICE_qualcommax_ipq807x_DEVICE_tplink_deco-x80-5g=y	
